{
  "name": "attestto-desktop",
  "private": false,
  "license": "Apache-2.0",
  "description": "Public Digital Infrastructure — sovereign identity desktop app with P2P mesh, offline verification, and Solana anchoring",
  "version": "0.1.0",
  "author": {
    "name": "Attestto",
    "email": "hello@attestto.com"
  },
  "homepage": "https://attestto.org",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "build:deps": "cd ../attestto-verify && pnpm build && cd ../attestto-mesh && pnpm build",
    "predev": "pnpm build:deps",
    "dev": "electron-vite dev",
    "prebuild": "pnpm build:deps",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@attestto/mesh": "link:../attestto-mesh",
    "@attestto/trust": "link:../attestto-trust",
    "@attestto/verify": "link:../attestto-verify",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@quasar/extras": "^1.17.0",
    "@signpdf/signpdf": "3.3.0",
    "@signpdf/utils": "3.3.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "@vueuse/core": "^14.2.1",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3",
    "iconv-lite": "^0.7.2",
    "jsqr": "^1.4.0",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "quasar": "^2.19.2",
    "selfsigned": "^5.5.0",
    "shamir-secret-sharing": "^0.0.4",
    "tesseract.js": "^7.0.0",
    "tweetnacl": "^1.0.3",
    "vue": "^3.5.32",
    "vue-router": "4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@quasar/vite-plugin": "^1.11.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/node-forge": "^1.3.14",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^39.8.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.0.0",
    "sass-embedded": "^1.98.0",
    "typescript": "~5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Attestto-com/attestto-desktop.git"
  },
  "keywords": [
    "public-digital-infrastructure",
    "sovereign-identity",
    "decentralized-identity",
    "electron",
    "desktop",
    "did",
    "verifiable-credentials",
    "p2p",
    "mesh",
    "solana",
    "offline-verification",
    "blind-courier"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ],
    "overrides": {
      "vite": "^6.4.2"
    }
  }
}
